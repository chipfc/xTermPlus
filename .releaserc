{
    "branches": [
        "master",
        "main"
    ],
    "plugins": [
        [
            "@semantic-release/commit-analyzer",
            {
                "preset": "conventionalcommits",
                "releaseRules": [
                    { "breaking": true, "release": "major" },
                    { "type": "feat", "release": "minor" },
                    { "type": "fix", "release": "patch" },
                    { "type": "hotfix", "release": "patch" },
                    { "type": "improve", "release": "patch" },
                    { "type": "refactor", "release": "patch" },
                    { "type": "revert", "release": "patch" },
                    { "type": "docs", "release": false },
                    { "type": "chore", "release": false },
                    { "type": "test", "release": false },
                    { "type": "build", "release": false },
                    { "type": "ci", "release": false }
                ]
            }
        ],
        [
            "@semantic-release/release-notes-generator",
            {
                "preset": "conventionalcommits",
                "presetConfig": {
                    "types": [
                        { "type": "feat", "section": "✨ Features", "hidden": false },
                        { "type": "fix", "section": "🐛 Bug Fixes", "hidden": false },
                        { "type": "hotfix", "section": "🚑 Hot Fixes", "hidden": false },
                        { "type": "improve", "section": "🚀 Improvements", "hidden": false },
                        { "type": "refactor", "section": "📦 Code Refactoring", "hidden": false },
                        { "type": "revert", "section": "⏪ Reverts", "hidden": false },
                        { "type": "docs", "section": "📚 Documentation", "hidden": false },
                        { "type": "chore", "section": "⚙️ Chore", "hidden": false },
                        { "type": "test", "section": "🔬 Test", "hidden": false },
                        { "type": "build", "section": "🏗️ Build", "hidden": false },
                        { "type": "ci", "section": "🔄 CI", "hidden": false }
                    ]
                }
            }
        ],
        [
            "@semantic-release/changelog",
            {
                "changelogFile": "CHANGELOG.md"
            }
        ],
        [
            "@semantic-release/exec",
            {
                "prepareCmd": "sed -i 's/version = \".*\"/version = \"${nextRelease.version}\"/' build.gradle.kts"
            }
        ],
        [
            "@semantic-release/git",
            {
                "assets": ["CHANGELOG.md", "build.gradle.kts"],
                "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
            }
        ],
        [
            "semantic-release-slack-bot",
            {
                "notifyOnSuccess": true,
                "notifyOnFail": true,
                "packageName": "xTermPlus",
                "markdownReleaseNotes": true,
                "unsafeMaxLength": 0,
                "onSuccessTemplate": {
                    "text": "🚀 A new version of *$package_name* has been released!\n\nCurrent version is *$npm_package_version*\n\n*Changelog:*\n\n$release_notes\n\n----\n<$repo_url/blob/main/CHANGELOG.md|Full CHANGELOG.md>"   
                }
            }
        ]
    ]
}
